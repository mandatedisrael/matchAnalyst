# Football data — football-data.org is recommended (free: 10 req/min)
# Register at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Fallback: API-Football / api-sports.io (free tier is ~100 req/day)
API_FOOTBALL_KEY=

# Polymarket Gamma API (read-only, no key required for public endpoints)
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com

# Weather
OPENWEATHER_API_KEY=

# 0G Compute — Router API (recommended)
ZEROG_ROUTER_API_KEY=
ZEROG_ROUTER_BASE_URL=https://router-api.0g.ai/v1
ZEROG_ROUTER_MODEL=glm-5.1

# 0G Compute — Direct wallet SDK (alternative)
ZEROG_PRIVATE_KEY=
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage (optional, for user memory & saved predictions)
ZEROG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://match-analyst-black.vercel.app (update when Vercel project is renamed)